# ============================================================
# Nestoria backend — environment variables
# Copy to `.env` for local dev. Set on Render dashboard for production.
# ============================================================

# ---------- Server ----------
PORT=5000
# Comma-separated list of allowed origins (no spaces). In dev: http://localhost:5173
# In production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ---------- PostgreSQL (Supabase) ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nestoria_db
DB_USER=postgres
DB_PASSWORD=change-me
# Set DB_SSL=true on Render (Supabase requires TLS).
DB_SSL=false
# If using Supabase connection pooler, use port 6543 instead of 5432.
# Connection string format: postgresql://user:password@host:port/database

# ---------- JWT ----------
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ---------- Supabase Storage (image uploads — optional) ----------
# Leave blank to disable /api/upload; everything else still works.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=hotel-images

# ---------- Google OAuth (optional) ----------
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include your frontend URL.
GOOGLE_CLIENT_ID=

# ---------- Unsplash (only needed to re-curate demo imagery) ----------
UNSPLASH_ACCESS_KEY=
