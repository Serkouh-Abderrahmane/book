# ============================================================
# Nestoria frontend — environment variables
# Copy to `.env` for local dev. Set on Vercel dashboard for production.
# Vite only exposes variables prefixed with VITE_ to client code.
# ============================================================

# Base URL of the Nestoria API. Include /api suffix.
# Local dev: http://localhost:5000/api
# Production: https://your-render-app.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Google OAuth Client ID — same one the backend uses to verify ID tokens.
# Leave blank to disable Google sign-in.
VITE_GOOGLE_CLIENT_ID=
